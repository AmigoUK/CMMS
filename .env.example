# CMMS — Environment Variables
# Copy to .env and fill in values. NEVER commit .env to git.

# --- Required ---
SECRET_KEY=your-secret-key-here
DATABASE_URL=mysql+pymysql://cmms_user:password@localhost/cmms?charset=utf8mb4

# --- Environment ---
# Set to "production" on deployed servers. Triggers fail-fast checks on
# SECRET_KEY / DATABASE_URL so a missing or default value crashes the
# boot rather than silently running on dev defaults.
ENV=development

# --- Server ---
PORT=5006

# --- Site ---
SITE_URL=https://your-domain.com
