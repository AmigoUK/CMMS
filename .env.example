# CMMS — Environment Variables
# Copy to .env and fill in values. NEVER commit .env to git.

# --- Required ---
SECRET_KEY=your-secret-key-here
DATABASE_URL=mysql+pymysql://cmms_user:password@localhost/cmms?charset=utf8mb4

# --- Server ---
PORT=5006

# --- Site ---
SITE_URL=https://your-domain.com
